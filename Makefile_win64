# 编译器与基础选项
CC = gcc
CFLAGS = -Wall -Wextra -g -Iinclude
LDFLAGS = 

# 目录设置
SRC_DIR = src
BUILD_DIR = build
TARGET = $(BUILD_DIR)/plane-war

# 自动获取源文件
SRC = $(wildcard $(SRC_DIR)/*.c)
OBJ = $(SRC:$(SRC_DIR)/%.c=$(BUILD_DIR)/%.o)

# ==========================================
# 跨平台环境检测与配置
# ==========================================
# 检测当前是否为 Windows 环境 (MinGW/MSYS2)
ifeq ($(OS),Windows_NT)
    # Windows 下手动指定 SDL2 路径（请根据实际路径修改）
    SDL2_INC = -I./SDL2/include
    SDL2_LIB = -L./SDL2/lib -lmingw32 -lSDL2main -lSDL2 -lSDL2_image -lSDL2_ttf
    CFLAGS += $(SDL2_INC)
    LDFLAGS += $(SDL2_LIB) -mwindows
    # Windows 创建目录和清理命令
    MKDIR = if not exist $(BUILD_DIR) mkdir $(BUILD_DIR)
    RMDIR = if exist $(BUILD_DIR) rd /s /q $(BUILD_DIR)
else
    # macOS / Linux 下使用 pkg-config
    CFLAGS += $(shell pkg-config --cflags sdl2 SDL2_image)
    LDFLAGS += $(shell pkg-config --libs sdl2 SDL2_image)
    # Unix 创建目录和清理命令
    MKDIR = mkdir -p $(BUILD_DIR)
    RMDIR = rm -rf $(BUILD_DIR)
endif

# ==========================================
# 构建规则
# ==========================================
all: $(TARGET)

$(TARGET): $(OBJ) | $(BUILD_DIR)
	$(CC) -o $@ $^ $(LDFLAGS)

$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c -o $@ $<

$(BUILD_DIR):
	$(MKDIR)

clean:
	$(RMDIR)

.PHONY: all clean